{
  "name": "payment-system-node-api",
  "version": "0.1.0",
  "description": "Payment System REST API — Node.js / Express / TypeScript",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "tar": "^7.5.11"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --config jest.config.cjs",
    "test:unit": "jest --config jest.config.cjs --selectProjects=unit",
    "test:domain": "jest --config jest.domain.config.cjs --selectProjects=unit --testPathPattern=src/domain --coverage",
    "test:application": "jest --config jest.application.config.cjs --selectProjects=unit --testPathPattern=src/application --coverage",
    "test:integration": "jest --config jest.infrastructure.config.cjs --selectProjects=integration --runInBand --coverage",
    "test:e2e": "jest --config jest.config.cjs --selectProjects=e2e --runInBand",
    "test:e2e:live": "jest --config jest.e2e.live.config.cjs --selectProjects=e2e --runInBand",
    "test:idempotency-concurrency": "tsx scripts/idempotency-concurrency.ts",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.0",
    "winston": "^3.17.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "typescript-eslint": "^8.15.0",
    "jest": "^29.7.0",
    "nock": "^14.0.0",
    "prettier": "^3.4.0",
    "prisma": "^6.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
