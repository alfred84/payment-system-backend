# =============================================================================
# Payment System Backend — Environment Variables
# Copy to .env and adjust values. Never commit .env to git.
# =============================================================================

# --- PostgreSQL (main) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=payments
POSTGRES_PORT=5432

# --- PostgreSQL (integration tests only) ---
POSTGRES_TEST_USER=postgres
POSTGRES_TEST_PASSWORD=postgres
POSTGRES_TEST_DB=payments_test
POSTGRES_TEST_PORT=5433

# --- Node API ---
NODE_ENV=development
NODE_API_PORT=3000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/payments
DATABASE_URL_TEST=postgresql://postgres:postgres@postgres-test:5432/payments_test
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
PROCESSOR_URL=http://python-service:8000

# --- Python processor ---
PYTHON_SERVICE_PORT=8000
PROCESSOR_APPROVAL_SEED=42
LOG_LEVEL=info
